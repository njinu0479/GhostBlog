{{!< default}}

{{#is "tag"}}
    <div style="font-size: 15px; font-weight: 700; color: #333; margin-bottom: 24px; border-bottom: 1px solid #f0f0f0; padding-bottom: 12px;">
        {{#tag}}<span class="category-title">{{name}}</span>{{/tag}} <span style="color: #e65f3e;">{{pagination.total}}</span>
    </div>
{{else}}
    <div style="font-size: 15px; font-weight: 700; color: #333; margin-bottom: 24px; border-bottom: 1px solid #f0f0f0; padding-bottom: 12px;">
        전체 글 <span style="color: #e65f3e;">{{pagination.total}}</span>
    </div>
{{/is}}

<div class="post-list">
    {{#foreach posts}}
    <article class="post-item" style="margin-bottom: 40px; display: flex; gap: 24px; align-items: center;">
        
        <div class="post-info" style="flex: 1; min-width: 0;">
            <h2 style="font-size: 16px; font-weight: 700; margin: 0 0 6px 0; letter-spacing: -0.5px;">
                <a href="{{url}}" style="color: #333;">{{title}}</a>
            </h2>
            
            <p style="font-size: 13px; color: #999; line-height: 1.5; margin: 0 0 8px 0; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                {{excerpt characters="160"}}
            </p>
            
            <div style="font-size: 12px; color: #aaa;">
                {{#if primary_tag}}<span class="tag-label" style="color: #444;">{{primary_tag.name}}</span> · {{/if}}{{date format="YYYY.MM.DD"}}
            </div>
        </div>

        {{#if feature_image}}
        <div class="post-thumb" style="width: 100px; height: 100px; flex-shrink: 0; overflow: hidden;">
            <a href="{{url}}">
                <img src="{{img_url feature_image size="m"}}" alt="{{title}}" style="width: 100%; height: 100%; object-fit: cover;">
            </a>
        </div>
        {{/if}}
        
    </article>
    {{/foreach}}
</div>

<nav class="tistory-pagination" data-current="{{pagination.page}}" data-total="{{pagination.pages}}"></nav>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        // 1. 번호 페이징 렌더링
        const paginationEl = document.querySelector('.tistory-pagination');
        if (paginationEl) {
            const current = parseInt(paginationEl.getAttribute('data-current')) || 1;
            const total = parseInt(paginationEl.getAttribute('data-total')) || 1;
            
            let basePath = window.location.pathname.replace(/\/page\/\d+\/?$/, '/');
            if (!basePath.endsWith('/')) basePath += '/';

            let html = '<div style="display: flex; justify-content: center; align-items: center; gap: 12px; margin-top: 60px; margin-bottom: 20px;">';
            
            for (let i = 1; i <= total; i++) {
                let pageUrl = i === 1 ? basePath : basePath + 'page/' + i + '/';
                if (i === current) {
                    html += `<span style="display: inline-flex; align-items: center; justify-content: center; width: 30px; height: 30px; background: #000; color: #fff; border-radius: 50%; font-size: 14px; font-weight: 600;">${i}</span>`;
                } else {
                    html += `<a href="${pageUrl}" style="display: inline-flex; align-items: center; justify-content: center; width: 30px; height: 30px; color: #555; font-size: 14px; text-decoration: none; transition: 0.2s;" onmouseover="this.style.fontWeight='600'; this.style.color='#000'" onmouseout="this.style.fontWeight='normal'; this.style.color='#555'">${i}</a>`;
                }
            }
            html += '</div>';
            paginationEl.innerHTML = html;
        }

        const tagLabels = document.querySelectorAll('.tag-label');
        tagLabels.forEach(label => {
            if (label.textContent.includes(' - ')) {
                label.textContent = label.textContent.replace(' - ', ' / ');
            }
        });

        const categoryTitle = document.querySelector('.category-title');
        if (categoryTitle) {
            let text = categoryTitle.textContent.trim();
            if (text.includes(' - ')) {
                categoryTitle.textContent = text.replace(' - ', ' / ');
            } else if (text.startsWith('-')) {
                categoryTitle.textContent = text.substring(1).trim();
            }
        }
    });
</script>
